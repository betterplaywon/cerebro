# cerebro 환경변수 예시 — 실제 값은 절대 커밋 금지. 복사해서 .env 로 사용.
# (apps/api 는 .env, apps/web 은 VITE_ 접두사만 클라이언트에 노출됨)

# ───────────── apps/api (서버 전용) ─────────────
NODE_ENV=development
PORT=8787
CORS_ORIGIN=http://localhost:5173

# Supabase (server)  — SERVICE_ROLE_KEY 는 서버에서만! 절대 클라이언트/VITE_ 금지
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 네이버 검색 API  (https://developers.naver.com)
# webkr·news·blog·cafearticle·kin 5종 사용(동일 키). 일일 25,000콜 공유.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 카카오(다음) 검색 API  (https://developers.kakao.com — REST API 키)
# web·blog·cafe 검색으로 국내 커뮤니티 커버리지 보완(ADR-0006). 미설정 시 비활성.
KAKAO_REST_API_KEY=

# 광범위 웹검색(구글/Brave/Tavily)은 보류 — 무료 티어 축소로 MVP엔 부적합(ADR-0005).
# SNS(X·인스타·페북)는 공식 API 부재·유료·승인 게이트로 보류(ADR-0006).
# 현재 검색 소스 = 위키백과(키 불필요) + 네이버(blog/cafe/kin 포함) + 카카오(키 입력 시).

# ───────────── apps/web (VITE_ 만 노출) ─────────────
VITE_API_BASE_URL=http://localhost:8787
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
