# cerebro 환경변수 예시 — 실제 값은 절대 커밋 금지. 복사해서 .env 로 사용.
# (apps/api 는 .env, apps/web 은 VITE_ 접두사만 클라이언트에 노출됨)

# ───────────── apps/api (서버 전용) ─────────────
NODE_ENV=development
PORT=8787
CORS_ORIGIN=http://localhost:5173

# 캐시 TTL(ms, 선택). 비우면 기본값 사용. ADR-0011 2단 캐시:
#  - CACHE_TTL_MS: 스냅샷(데이터+리포트) 캐시. 기본 1800000(30분).
#  - REPORT_CACHE_TTL_MS: LLM 리포트 캐시. 기본 604800000(7일). 비싼 LLM 호출을 길게 재사용.
CACHE_TTL_MS=
REPORT_CACHE_TTL_MS=
# 기동 시 시드 프리웜(true/false, 기본 false). ⚠️ 인메모리 캐시 + 무료 spin-down이면
# 콜드스타트마다 재실행 = 재호출 비용. 영속 캐시/안정 인스턴스에서만 ON 권장(ADR-0011).
PREWARM_ON_START=

# 개인 전용 모드(true/false, 기본 false). ON이면 네이버·카카오(Layer A) 검색결과도
# LLM 활용 리포트 입력·인용·캐시에 포함('처음처럼' 한국어/시의성 깊이 복원, ADR-0018).
# ⚠️ 운영자 본인만 쓰는 비공개·비영리 인스턴스에서만 ON — 네이버·카카오 약관은 검색결과의
#    재가공·장기저장을 금지한다(ADR-0014). 공개 배포·타인 제공·수익화 시 반드시 비우거나 false.
PERSONAL_USE_MODE=

# Supabase (server)  — SERVICE_ROLE_KEY 는 서버에서만! 절대 클라이언트/VITE_ 금지
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 네이버 검색 API  (https://developers.naver.com)
# webkr·news·blog·cafearticle·kin 5종 사용(동일 키). 일일 25,000콜 공유.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 카카오(다음) 검색 API  (https://developers.kakao.com — REST API 키)
# web·blog·cafe 검색으로 국내 커뮤니티 커버리지 보완(ADR-0007). 미설정 시 비활성.
KAKAO_REST_API_KEY=

# 공공데이터포털 서비스 키  (https://www.data.go.kr — 금융위 기업기본정보, ADR-0015)
# Layer B 한국어 기업 사실데이터(상업 OK). 미설정 시 publicdata 어댑터 비활성.
# ⚠️ 포털의 'Decoding' 키를 입력(어댑터가 1회만 인코딩 — Encoding 키는 이중 인코딩됨).
DATA_GO_KR_SERVICE_KEY=

# Claude 분석 — "활용 관점 리포트"(핵심 요약 + 관점별 활용법) 생성(ADR-0008).
# 미설정 시 LLM 분석 비활성 → 기존 휴리스틱 그래프로 폴백(지출 0). 검색당 1회 호출.
ANTHROPIC_API_KEY=
# 분석 모델(선택). 기본=claude-sonnet-4-6(비용·품질 균형). 변경 시에만 입력.
ANALYSIS_MODEL=

# LLM 예산 서킷 브레이커(선택, ADR-0013). 비우면 기본값 사용. 시크릿 아님.
#  - ANTHROPIC_BUDGET_USD: 월(UTC 달력) 누적 추정비용 상한(USD). 기본 8($8.8 한도 미만 헤드룸).
#    도달 시 LLM 분석 자동 차단 → 휴리스틱 폴백(지출 0). 0=항상 차단(킬 스위치).
#  - ANALYSIS_INPUT_USD_PER_MTOK / ANALYSIS_OUTPUT_USD_PER_MTOK: 비용 추정 단가(USD per 1M 토큰).
#    기본 Sonnet 4.6 = 3 / 15. ANALYSIS_MODEL 교체 시 단가 동기화.
ANTHROPIC_BUDGET_USD=
ANALYSIS_INPUT_USD_PER_MTOK=
ANALYSIS_OUTPUT_USD_PER_MTOK=

# 광범위 웹검색(구글/Brave/Tavily)은 보류 — 무료 티어 축소로 MVP엔 부적합(ADR-0005).
# SNS(X·인스타·페북)는 공식 API 부재·유료·승인 게이트로 보류(ADR-0007).
# 현재 검색 소스 = 위키백과(키 불필요) + 네이버(blog/cafe/kin 포함) + 카카오(키 입력 시).

# ───────────── apps/web (VITE_ 만 노출) ─────────────
VITE_API_BASE_URL=http://localhost:8787
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
