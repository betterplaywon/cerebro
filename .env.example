# cerebro 환경변수 예시 — 실제 값은 절대 커밋 금지. 복사해서 .env 로 사용.
# (apps/api 는 .env, apps/web 은 VITE_ 접두사만 클라이언트에 노출됨)

# ───────────── apps/api (서버 전용) ─────────────
NODE_ENV=development
PORT=8787
CORS_ORIGIN=http://localhost:5173

# Supabase (server)  — SERVICE_ROLE_KEY 는 서버에서만! 절대 클라이언트/VITE_ 금지
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 네이버 검색 API  (https://developers.naver.com)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 구글 Programmable Search
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# ───────────── apps/web (VITE_ 만 노출) ─────────────
VITE_API_BASE_URL=http://localhost:8787
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
